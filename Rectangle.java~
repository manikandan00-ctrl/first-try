class Rectangle {
    int length;
    int breadth;
    Rectangle(int l, int b) {
        length = l;
        breadth = b;
    }
    void displayArea() {
        int area = length * breadth;
        System.out.println("Area of Rectangle = " + area);
    }
    public static void main(String[] args) {
        Rectangle r = new Rectangle(10, 5);
        r.displayArea();
    }
}